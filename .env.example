# Variables de entorno para docker-compose (12-factor).
# Copia este fichero a .env y ajusta los valores; .env NO se versiona.
# Si no defines .env, docker-compose usa los defaults locales del propio compose.

# Contraseña del usuario de aplicación de la BD (superuser).
# La consumen tanto el servicio 'db' (MYSQL_PASSWORD) como 'web' (DB_PASSWORD -> config.inc.php).
DB_PASSWORD=8hYLKcthnx

# Contraseña de root de la BD (solo servicio 'db').
DB_ROOT_PASSWORD=root

# BD externa de notificaciones (time-tracking) usada por customerPortal2/Notifications.
# Antes estaba hardcodeada en el código; ahora se inyecta por entorno. Vacío por defecto
# (el servicio no existe en el entorno local). Rellenar solo en despliegues que lo tengan.
NOTIF_DB_HOST=127.0.0.1:3306
NOTIF_DB_USER=timeuser
NOTIF_DB_PASSWORD=
