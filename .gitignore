!db_init/01-instance-users.sql

# ── Basura de Windows / WSL ──
*.Zone.Identifier

# ── Respaldo local del .gitignore del cliente (no publicar) ──
src/.gitignore.cliente.bak

# ── Indicaciones internas de la prueba técnica (no publicar) ──
INDICACIONES.md

# ── Contexto de traspaso para IA (credenciales/notas internas, no publicar) ──
CONTEXTO.md

# ── Documento interno adicional de la prueba (no publicar) ──
NUEVO_DOC.md

# ── Cachés y datos de runtime de vtiger (se regeneran solos) ──
src/Smarty/templates_c/
src/cache/
src/logs/
src/storage/

# ── Config de editores / IDE ──
src/.idea/
.idea/
.vscode/

