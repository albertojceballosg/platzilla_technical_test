<settings>
  <font>Tahoma</font>
  <hide_bullets_count>18</hide_bullets_count>
  <background>
    <alpha>90</alpha>
    <border_alpha>10</border_alpha>
  </background>
  <plot_area>
    <alpha>36</alpha>
    <border_alpha>41</border_alpha>
    <margins>
      <left>50</left>
      <right>40</right>
      <top>30</top>
      <bottom>65</bottom>
    </margins>
  </plot_area>
  <grid>
    <x>
      <alpha>10</alpha>
      <approx_count>59</approx_count>
    </x>
    <y_left>
      <alpha>10</alpha>
    </y_left>
  </grid>
  <axes>
    <x>
      <width>1</width>
      <color>0D8ECF</color>
    </x>
    <y_left>
      <width>1</width>
      <color>0D8ECF</color>
    </y_left>
  </axes>
  <indicator>
    <color>009900</color>
    <x_balloon_text_color>FFFFFF</x_balloon_text_color>
    <line_alpha>50</line_alpha>
    <selection_color>0D8ECF</selection_color>
    <selection_alpha>20</selection_alpha>
  </indicator>
  <balloon>
    <only_one>1</only_one>
    <color>000000</color>
    <max_width>202</max_width>
    <corner_radius>1</corner_radius>
    <border_width>1</border_width>
    <border_color>000000</border_color>
    <border_alpha>100</border_alpha>
  </balloon>
  <zoom_out_button>
    <text_color_hover>FF0F00</text_color_hover>
  </zoom_out_button>
  <help>
    <button>
      <color>FCD202</color>
      <text_color>000000</text_color>
      <text_color_hover>FF0F00</text_color_hover>
    </button>
    <balloon>

      <text><![CDATA[Click on the graph to turn on/off value baloon <br/><br/>Click on legend key to show/hide graph<br/><br/>Mark the area you wish to enlarge]]></text>
      <color>FCD202</color>
      <text_color>000000</text_color>
    </balloon>
  </help>
  <graphs>
    <graph gid="0">
      <title>Anomaly</title>
      <color>0D8ECF</color>
      <color_hover>FF0F00</color_hover>
      <selected>0</selected>
      <data_labels_position>below</data_labels_position>
    </graph>
    <graph gid="1">
      <title>Smoothed</title>
      <color>B0DE09</color>
      <color_hover>FF0F00</color_hover>
      <line_width>2</line_width>
      <fill_alpha>30</fill_alpha>
      <selected>0</selected>
      <balloon_alpha>89</balloon_alpha>
      <data_labels_text_color>000000</data_labels_text_color>
      <data_labels_text_size>6</data_labels_text_size>
      <bullet>round</bullet>
      <bullet_size>1</bullet_size>
    </graph>
  </graphs>
  <labels>
    <label lid="0">
      <y>25</y>
      <text_size>8</text_size>
      <align>center</align>
    </label>
  </labels>
</settings>