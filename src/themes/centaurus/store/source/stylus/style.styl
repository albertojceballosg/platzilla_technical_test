
//Nomenclatura de variables -> n_*: texto-nombre, c_*: color, f_*: que corresponde a fuentes, t_*: atributo de tamaño


@import "vars";

n_fuente = "Open Sans"
c_tema = #00cc6b
c_tema_sombra = #00af5a
c_background = #EEEEEE
f_size = 2em
f_icon = .7em
f_titulo = 2.5em n_fuente, sans-serif
f_subtitulo = bold 1.5em n_fuente, sans-serif
f_descripcion = 1.2em n_fuente, sans-serif
f_principal = 1.7em n_fuente, sans-serif
t_subtitulo = 1.4em


$green-color = #2DCC70
$red-color = #FF4B3A
$yellow-color = #FECE00
$blue-color = #01B9FF
$s_border = 2px
$black = #394048
$green-color-opacity =  #27AE61
$bp-xs = 490px

$brand-color = $palette-green
$bg-color = #E7E7E7
$dark-gray = #626E6E
$light-gray = #F1F1F1
$separator-color = #d9d9d9

/*
ESTILOS PARA TIENDA DE APLICACIONES 03
*/

.sub-contenido
	width 80%
	float center
	margin:  auto
	padding-top 0
	padding-bottom 0	

.rsl-min //resolucion minima
	text-align center
	padding 10px 0 20px 0

.sub-cabecera
	background-color #E6E6E6
	padding 10px 20px
	
.subtitulo
	padding 60px 0
	text-align center
	font f_titulo
	font-style italic
	color #151111

	@media (max-width :360px)
		font-size 1.4em		

	@media (max-width :480px)
		font-size 1.7em
		padding 50px 5px
		
	@media (max-width :992px)
		font-size 1.8em
		padding 50px 5px						

.subtitulo-2 
	padding 0 10px	 
	text-align left
	font f_subtitulo
	color c_tema
	
	@media (max-width :768px)
		font-size 1.4em

	@media (max-width :360px)
			font-size 1em

.descripcion 
	padding 5px 10px 20px 10px
	font f_descripcion
	
	@media (max-width :360px)
		font-size 1em

.titulo
	font-weight bold
	font 1.4em n_fuente, sans-serif

.imagen
	padding 20px 60px 35px 60px

	@media (max-width :780px)		
		margin auto
		padding 20px 0 40px 0!important

	@media (min-width: 769px) and (max-width: 992px)
		padding 30px 0

.imagen-logo	
	width 90px
	height 90px
	padding auto 30px

	@media (max-width :380px)
		float none
		
.logo1
	@extends .imagen-logo
	margin-left 24px	
	
.logo2
	@extends .imagen-logo
	margin-right 24px
	
.logo1	
.logo2		
	@media (max-width :360px)
		width 60px
		height 60px
		
	@media (max-width :768px)
		margin 0 30px
		
	@media (min-width: 769px) and (max-width: 992px)
		margin 0 30px

.cabecera-ventana
	height 30px

.icono
	padding 10px 0
	color #B6ABAB
	font-size f_icon	

.opciones-ventana	
	@extends .icono	
	@extends .cabecera-ventana
	float right

.titulo-ventana
	@extends .icono
	@extends .cabecera-ventana
	margin -25px 0 20px 0	
	padding-left 12px
	color #9C9393	
	font-size 1em

	@media (max-width :790px)
		font-size 1em
		padding 10px 5px

.botones-cabecera
	padding-top 10px
	
.boton-rectangular
	font-size .7em
	border-radius 0 !important
	-moz-border-radius 0 !important
	-webkit-border-radius 0 !important 
	-khtml-border-radius 0 !important
	
.btn-r-success
	@extends .boton-rectangular
	border-bottom 4px solid c_tema_sombra
	text-transform uppercase
	font-weight bold

.btn-r-cancel
	@extends .boton-rectangular
	color #999595	
	
.rsl-min .imagen-logo
	margin auto 10%

.cen
	@media (max-width :780px)
		text-align center
		
.rsl-min //obviar resolucion minima

	@media (min-width: 769px) and (max-width: 992px)
		display: none !important
	
	@media (min-width: 993px) and (max-width: 1200px)
		display: none !important
		
	@media (min-width: 1201px)
		display: none !important	
		
.rsl-nml //obviar normal
	@media (max-width :769px)
		display: none !important
		
.wm-btn
	max-width 100px
	min-width 100px
	
.btn-lnk-cancel
	font-size .7em
	color #A6A6A6
	text-transform capitalize !important
	text-decoracion none !important
	border 0

#login-header
	background-color #E4E4E4
	padding 0 10% 20px 10%

#login-box
	max-width 80%
	
#login-logo
	background-color #E4E4E4

#login-box-inner
	padding 0 10%

.logo
	img
		margin-left 4px
		float right

.opciones-ventana i
	font-weight normal
	font-style normal
	margin-right -10%

/*
ESTILOS PARA TIENDA DE APLICACIONES 01
*/

//---Elementos de contenido---
	
.tabs-wrapper .tab-content
	padding 40px 10px 40px 50px
		
	@media screen and (min-width: $bp-sm)
		padding 40px 20px 40px 40px

.tab-app
	padding 0 30px 20px 50px
	
	@media screen and (max-width: $bp-xs)
		padding-left 0
		padding-right 0

	@media screen and (max-width: $bp-sm)
		padding-bottom 0
	
	@media screen and (min-width: $bp-sm)
		padding 40px 10px 40px 10px

.title-content
	opacity 1
	padding 50px 0 70px
	font-size 1.2em	
	
.title-description
	font-size 1.2em
	width 700px
	padding 0 !important		
	color $dark-gray

	@media screen and (max-width: $bp-xs)
		font-size 1em	
			
	@media screen and (max-width: $bp-md)
		width 100%

//---Colores para componentens---
.bg-red
	background-color $red-color

.bg-green
	background-color $green-color
	
.bg-yellow
	background-color $yellow-color
	
.bg-blue
	background-color $blue-color
	
//---Componentes para sección de aplicaciones---
	
.app-img
	border-radius 50%
	-moz-border-radius 50% 
	-webkit-border-radius 50%
	-khtml-border-radius 50%
	background-clip padding-box
	margin-bottom 15px
	background-color white
	border 2px solid #e6e6e6
	padding 10px
	width 130px
	
	@media screen and (max-width: $bp-xs)
		width 90px
		
.app-img-align
	text-align center
	
.app-description-align
	text-align left
	p
		font-size 1em !important		
		@media screen and (max-width: $bp-xs)
			font-size .9em !important
			
	.btn
		@media screen and (max-width: $bp-xs)
			font-size .8em

.app-container
	line-height 1.6
	border $s_border solid grey
	padding 0	
	
.app-container-noside	
	border-right 0 !important
	border-left 0 !important	
	
.app-container-top	
	@extends .app-container-noside
	border-bottom 0 !important

.app-container-bottom
	@extends .app-container-noside
	border-top 0 !important
	
.app-container-red
	@extends .app-container
	border-color $red-color
		
.app-container-yellow
	@extends .app-container
	border-color $yellow-color

.app-container-green
	@extends .app-container
	border-color $green-color
	
.app-container-blue
	@extends .app-container
	border-color $blue-color

.app-container-white
	@extends .app-container
	border-color white

.app-container-box
	padding 60px 0 20px 0px !important
	color #9E9E9E
	
	@media screen and (max-width: $bp-sm)
		text-align center
	
.app-container-label
	width 250px
	height 40px
	text-align center
	font-size .7em

	@media screen and (max-width: $bp-xs)
		font-size .8em 
	
	@media screen and (max-width: $bp-sm)
		display inline-block
		font-size .7em 

.app-block
	@media screen and (max-width: $bp-md)
		padding-bottom 40px
		
.app-status
	color #B3B3B3
	text-transform uppercase

.app-status-icon
	color $green-color
	font-size 1.4em !important
		
.app-title	
	font-weight bold
	text-transform uppercase
	color $dark-gray !important
	font-size 0.8em !important

#simulador	
	width 284px
	padding 10px
	background none
	height 400px
	position absolute
	right 0
	top 0
	color white !important
	padding 40px  7px 0  7px !important
	font-size .98em

	@media screen and (max-width: $bp-md)	
		display none
			
	@media screen and (min-width: $bp-sm)
		float right !important
		
#simulador .item
	background-color $green-color-opacity
	height 50px
	margin 6px 0
	padding 5px 10px
	font-size .9em

#simulador a
	float right	
	font-size 1em
	color white

#simulador .sub-frame
	color grey
	font-size .9em
	padding 10px 5px
	text-align center
	
#simulador .btn
	width 100px
		
#simulador .lab
	width 100px
	height 32px
	font-size .9em !important
	text-align center
	padding-top 6px
	border-radius 3px !important
	-moz-border-radius 3px !important
	-webkit-border-radius 3px !important
	-khtml-border-radius 3px !important
	background #95A5A5
	
#simulador .main-box-body
	padding-top 20px

.price
	text-align right
	font-weight bold
	font-size 1.1em !important

#simulador-min
	position fixed
	left 0
	bottom  0
	width 100%
	height 60px
	background $green-color
	
	@media screen and (min-width: $bp-md)	
		display none
	
#simulador-min .item	
	background-color $green-color-opacity
	margin 6px 0 30px 0
	padding 5px 10px 
	margin-left 20px
	font-size .9em
	text-align center
	overflow hidden
	color white	
	
	@media screen and (min-width: $bp-sm)
		margin 6px auto
		width 50%
		height 46px
		
#simulador-min .btn
	margin 6px 0
	padding 5px 10px 
	margin-right 20px
	height 46px !important
	line-height 32px
	
	@media screen and (min-width: $bp-sm)
		margin 6px auto
		width 70% !important
		float left !important


//---Posicionamiento fijo---


.affix
	top 10px
	width 300px
		
.fix
	overflow hidden
	padding-top 10px	
	margin-bottom 10px

#wrapper 
	overflow hidden
	position relative

#content 
	margin-right 10px
	min-height 1200px

#portamento_container 
	position absolute 
	right 0
	top 0/* take the absolute positioning of the simulador */

#portamento_container #simulador
	padding-left 30px !important

#portamento_container #simulador.fixed 
	position fixed
	right auto
	top auto /* become fixed position, but reset the top and right values */
	padding-left 30px !important

//---Botones y Etiquetas---

.btn-outline
	background-color none
	border 2px solid
	padding 5px
	font-weight bold
	text-transform uppercase
	
.btn-outline-green
	@extends .btn-outline
	border-color $green-color
	color $green-color !important
		
.btn-label-grey
	background-color #E6E6E6
	border-color #E6E6E6
	color grey !important
	text-transform uppercase
	
.btn-label-grey:hover
	color white !important
	border-color #7f8c8d

.alto150
	height 150px
